{
  "manifest_version": 3,
  "name": "PADS \u2014 Smart Coupons",
  "version": "1.0.0",
  "description": "PADS automatically shows exclusive coupon codes while you shop on your favourite websites. Save money instantly.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "PADS Coupons"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.myntra.com/*",
        "https://myntra.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.myntra.com/*",
    "https://myntra.com/*"
  ]
}